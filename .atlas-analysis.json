  "keyFeatures": [
    "Plugin Manager — install, update, activate/deactivate, version history, WP.org search",
    "Theme Manager — browse, activate, upload, export, version history",
    "File Manager — Monaco Editor with full syntax highlighting, upload, rename, delete",
    "Database Manager — table browser, row CRUD, search & replace, SQL runner, export",
    "User Manager — role management, username rename, login-as impersonation",
    "Security Suite — admin URL protection, login limiter, 2FA, core integrity, IP blocklist",
    "Security Scanner — malware detection, vulnerability CVE check, SSL monitor",
    "Maintenance Mode — fully styled maintenance page with live preview",
    "Image Tools — WebP/AVIF conversion, thumbnail regeneration, SVG uploads",
    "Agency Tools — mail interceptor, white-label login, admin UI customiser, client reports",
    "Developer Utilities — hook explorer, REST API tester, dummy data generator, rewrite tester",
    "Code Snippets — run custom PHP, CSS, JS from dashboard with Monaco Editor",
    "Database Backup — full/table SQL dumps, scheduled backups, download/delete",
    "Cron Manager — event scheduling, custom schedules, manual trigger, health check",
    "Media Manager — orphan cleanup, duplicate finder, image compression"
  ],
